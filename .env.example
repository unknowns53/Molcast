# §10 environment variables. Copy this file to `.env` for local runs.
# `.env` is gitignored.

# REQUIRED for production. Take it from the Slack App "Basic Information"
# page. For local development you can leave it blank and bypass signing
# by hitting /slack/mol with a stubbed header in a test.
SLACK_SIGNING_SECRET=

# `ephemeral` (only the invoker sees the viewer URL) or `in_channel`
# (everyone in the channel sees it). Default ephemeral.
SLACK_RESPONSE_TYPE=ephemeral

# Public URL of the Cloud Run service. Used to build the /view/{id}
# link returned to Slack. Leave blank to reconstruct from the request.
BASE_URL=

# Firestore collection name.
FIRESTORE_COLLECTION=molecules

# TTL in days for /view/{id} URLs.
RETENTION_DAYS=7

# Maximum atom count (after AddHs) for the RDKit pipeline.
MAX_ATOMS=200

# Phase 3 only. `local` = py2opsin then EBI Web fallback;
# `local_only` = py2opsin only; `web` = EBI Web only (handy for local
# development without a JRE).
OPSIN_BACKEND=local
OPSIN_JAR_PATH=/opt/opsin/opsin.jar
OPSIN_WEB_URL=https://opsin.ch.cam.ac.uk/opsin/

LOG_LEVEL=INFO

# Local-only; Cloud Run sets PORT itself.
PORT=8080

# ---------------------------------------------------------------------
# Local-dev convenience flags. NEVER set these in a Cloud Run deploy.
# Both default to False; setting either to "true" emits a warning log
# line at startup so a misconfigured prod is obvious.
# ---------------------------------------------------------------------
# Bypass Slack request signature verification on /slack/mol. Useful for
# curl-driven testing and tunnel-based dev where the prod signing
# secret is not available.
DEV_SKIP_SIGNATURE_VERIFICATION=false
# Run the name: branch inline (in a background thread) instead of
# enqueueing to Cloud Tasks. Lets `/mol name: ...` work locally without
# a Cloud Tasks queue or invoker service account.
DEV_INLINE_NAME_RESOLUTION=false
